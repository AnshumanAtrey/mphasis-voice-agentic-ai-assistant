# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Settings
LLM_MODEL=gemini-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# Speech Recognition
SPEECH_ENGINE=google
SPEECH_LANGUAGE=en-US

# Text-to-Speech
TTS_ENGINE=pyttsx3
TTS_RATE=150
TTS_VOLUME=1.0

# Context
CONTEXT_WINDOW_SIZE=5
INTENT_CONFIDENCE_THRESHOLD=0.6

# Logging
LOG_LEVEL=INFO
